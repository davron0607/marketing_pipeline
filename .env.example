# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/survey_analytics

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# MinIO (object storage)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=survey-datasets
MINIO_SECURE=false

# Auth
SECRET_KEY=change-me-in-production

# App
DEBUG=false
APP_NAME=Survey Analytics API

# Frontend (baked at build time for Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3505
